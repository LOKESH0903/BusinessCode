@page
@model SRRAMOils.Pages.OrganizationModel
@{
}
<div class="container mt-5">
    <h2 class="mb-4">Add Organization</h2>
    <form id="orgForm" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label for="vendorName" class="mb-2">Organization Name</label>
            <input type="text" class="form-control" id="txtOrganizationName" name="OrganizationName" placeholder="Enter Organization name">
        </div>
        <button type="button" id="btnSubmit" class="btn btn-primary">Save</button>
    </form>
</div>

<h2>Organizations</h2>

@if (Model.Organizations == null || Model.Organizations.Count == 0)
{
    <p>No data.</p>
}
else
{
    <div class="table-responsive">
        <table id="tableOrginazations" class="org-table" role="table" aria-label="Organizations table">
            <caption class="org-caption">List of organizations</caption>
            <thead>
                <tr>
                    @foreach (var header in Model.Organizations[0].Keys)
                    {
                        <th scope="col">@header</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Organizations)
                {
                    <tr>
                        @foreach (var kv in row)
                        {
                            <td>@kv.Value</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <script type="text/javascript">
        $(function () {
            $('#btnSubmit').on('click', function () {
                var name = $('#txtOrganizationName').val().trim();
                if (!name) {
                    alert('Please enter an organization name.');
                    return;
                }

                // Read antiforgery token from the generated hidden input
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: window.location.pathname,
                    method: 'POST',
                    data: {
                        OrganizationName: name,
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        if (response && response.success) {
                            alert('Saved: ' + response.name);
                            // Optionally: append to table or reload page to refresh list
                            // location.reload();
                            $('#txtOrganizationName').val('');
                        } else {
                            alert('Save failed.');
                        }
                    },
                    error: function (xhr) {
                        alert('Error: ' + (xhr.responseText || xhr.statusText));
                    }
                });
            });
        });
    </script>
    
}