<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SRRAMOils</title>
    <script type="importmap"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js" integrity="sha256-..." crossorigin="anonymous"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SRRAMOils.styles.css" asp-append-version="true" />
	<link href="~/css/csstables.css" rel="stylesheet" />
    <style>
        /* Small, focused styles for the vertical sidebar layout */
        .sidebar {
            min-width: 220px;
            max-width: 260px;
        }
        .sidebar .nav-link {
            color: #333;
        }
        .sidebar .nav-link.active {
            background-color: #0d6efd;
            color: #fff;
        }
        /* Ensure main content is scrollable and full height */
        .vh-container {
            min-height: 100vh;
        }
    
        }
    </style>
</head>
<body>
    <header>
        <!-- Top navbar for small screens with toggler to show/hide sidebar -->
        <nav class="navbar navbar-light bg-white border-bottom d-md-none">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Sample Notes</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
        </nav>

        <!-- Main header shown on md+ inside the sidebar -->
    </header>

    <div class="container-fluid vh-container">
        <div class="row g-0">
            <!-- Sidebar -->
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse vh-100 p-0">
                <div class="position-sticky top-0 d-flex flex-column h-100">
                    <div class="px-3 py-3 border-bottom d-none d-md-block">
                        <a class="navbar-brand" asp-area="" asp-page="/Index">Sample Notes</a>
                    </div>

                    <ul class="nav nav-pills flex-column mb-auto px-2 mt-3">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">   
                            <a class="nav-link text-dark" asp-area="" asp-page="/Vendor">Add Vendor</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Organization">Organization</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/VendorPurchase">Vendor Purchase</a>
                        </li>
                        <li class="nav-item">
							<a class="nav-link text-dark" asp-area="" asp-page="/VendorPurchaseReport">Vendor Purchase Report</a>
                        </li>
                    </ul>

                    <div class="mt-auto px-3 py-3 border-top">
                        <small class="text-muted">&copy; 2026 - SRRAMOils</small><br />
                        <a class="link-secondary" asp-area="" asp-page="/Privacy">Privacy</a>
                    </div>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-4 py-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="border-top footer text-muted d-none d-md-block">
        <div class="container">
            <!-- Footer content is included in the sidebar for md+; keep this as fallback for narrow screens -->
            &copy; 2026 - SRRAMOils - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
